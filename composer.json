{
    "name": "patrickrobrecht/flexible-event-and-booking-manager",
    "type": "project",
    "description": "Manage events, their booking forms and bookings via a web-based platform.",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "barryvdh/laravel-dompdf": "^3.1",
        "guzzlehttp/guzzle": "^7.13",
        "intervention/validation": "^4.6",
        "laravel/framework": "^13.18",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.3",
        "phpoffice/phpspreadsheet": "^5.8",
        "portavice/bladestrap": "^1.6",
        "spatie/laravel-query-builder": "^7.3",
        "spatie/laravel-sluggable": "^4.0",
        "stechstudio/laravel-zipstream": "^5.10"
    },
    "require-dev": {
        "brianium/paratest": "^7.23",
        "fakerphp/faker": "^1.24",
        "fruitcake/laravel-debugbar": "^4.4",
        "kkomelin/laravel-translatable-string-exporter": "^1.26",
        "larastan/larastan": "^3.10",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.2",
        "portavice/laravel-pint-config": "^3.0",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "cs": [
            "@csPHP",
            "npm run cs"
        ],
        "csPHP": [
            "pint --config vendor/portavice/laravel-pint-config/pint.json --test"
        ],
        "csfix": [
            "@csfixPHP",
            "npm run csfix"
        ],
        "csfixPHP": [
            "pint --config vendor/portavice/laravel-pint-config/pint.json"
        ],
        "production": [
            "@composer install --optimize-autoloader --no-dev"
        ],
        "stan": [
            "Composer\\Config::disableProcessTimeout",
            "phpstan analyse --memory-limit=1G"
        ],
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/paratest --exclude-group serial",
            "vendor/bin/phpunit --group serial"
        ],
        "test-with-coverage": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/paratest --exclude-group serial --coverage-html .phpunit.coverage"
        ],
        "translate": [
            "@php artisan translatable:export de"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "audit": {
            "abandoned": "fail"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
