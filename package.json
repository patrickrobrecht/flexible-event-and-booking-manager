{
    "private": true,
    "scripts": {
        "cs": "npm run csCSS && npm run csJS",
        "csCSS": "stylelint resources/sass/*.scss",
        "csJS": "eslint resources/js/*.js eslint.config.cjs vite.config.mjs",
        "csfix": "npm run csfixCSS && npm run csfixJS",
        "csfixCSS": "stylelint resources/sass/*.scss --fix",
        "csfixJS": "eslint resources/js/*.js eslint.config.cjs vite.config.mjs --fix",
        "dev": "vite",
        "build": "vite build"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fortawesome/fontawesome-free": "^7.3.0",
        "alpinejs": "^3.15.12",
        "axios": "^1.18.1",
        "bootstrap": "^5.3.8",
        "eslint": "^10.6.0",
        "laravel-vite-plugin": "^3.1.0",
        "rapidoc": "^9.3.8",
        "sass": "^1.101.0",
        "stylelint": "^17.14.0",
        "stylelint-config-recommended-scss": "^17.0.1",
        "vite": "^8.1.3",
        "vite-plugin-static-copy": "^4.1.1"
    },
    "allowScripts": {
        "@parcel/watcher": false,
        "@scarf/scarf": false,
        "@tree-sitter-grammars/tree-sitter-yaml": false,
        "tree-sitter": false,
        "core-js-pure": false,
        "tree-sitter-json": false
    },
    "stylelint": {
        "extends": "stylelint-config-recommended-scss",
        "plugins": [
            "stylelint-scss"
        ]
    }
}
